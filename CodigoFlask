def clasificar_irca(irca):
    try:
        irca = float(irca)
    except ValueError:
        return "ND"
    if irca <= 5:
        return "Sin riesgo"
    elif irca <= 14:
        return "Riesgo bajo"
    elif irca <= 35:
        return "Riesgo medio"
    elif irca <= 80:
        return "Riesgo alto"
    else:
        return "Riesgo inviable sanitariamente"

def entrenar_modelo(df):
    df = df.dropna()
    df['Nivel_IRCA'] = df['IRCA'].apply(clasificar_irca)
    X = df[['IRCAUrbano', 'IRCARural']]
    y = df['Nivel_IRCA']
    modelo = GradientBoostingClassifier()
    modelo.fit(X, y)
    return modelo

